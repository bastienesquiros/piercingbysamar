# ══════════════════════════════════════════════════════
#  Piercing by Samar — Variables d'environnement prod
#  Copie ce fichier en .env et remplis les valeurs
#  NE JAMAIS committer le .env
# ══════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=piercingbysamar
DB_USERNAME=piercingbysamar
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── JWT ──────────────────────────────────────────────
# Générer avec : openssl rand -base64 64
JWT_SECRET=CHANGE_ME_AT_LEAST_64_CHARS_RANDOM_STRING
JWT_EXPIRATION_MS=86400000

# ── Nuxt ──────────────────────────────────────────────────────
NUXT_OG_IMAGE_SECRET=REPLACE_ME_GENERATE_WITH_npx_nuxt-og-image_generate-secret

# ── Traefik / SSL ─────────────────────────────────────────────
ACME_EMAIL=ton@email.com

# ── Stripe ────────────────────────────────────────────────────
STRIPE_PUBLIC_KEY=pk_live_REPLACE_ME
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
# Mettre à "false" pour désactiver Stripe (paiement en ligne + UI)
STRIPE_ENABLED=true

# ── Frontend URL (sans slash final) ──────────────────
FRONTEND_URL=https://piercingbysamar.com

# ── Mail (ex: Brevo, Mailgun, Resend…) ───────────────
MAIL_HOST=smtp.brevo.com
MAIL_PORT=587
MAIL_USERNAME=REPLACE_ME
MAIL_PASSWORD=REPLACE_ME
MAIL_FROM=noreply@piercingbysamar.com
WHATSAPP_NUMBER=212781570083

# ── Cloudflare R2 ────────────────────────────────────
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_BUCKET=piercingbysamar
S3_ACCESS_KEY=REPLACE_ME
S3_SECRET_KEY=REPLACE_ME
S3_PUBLIC_URL=REPLACE_ME

# ── Spring profile (ne pas toucher) ──────────────────
SPRING_PROFILES_ACTIVE=prod
